{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "repo-insight-front",
  "version": "0.1.0",
  "identifier": "com.dott13.repo-insight-front",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "plugins" :{
    "deep-link": {
      "desktop": {
        "schemes": ["repo-insight"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "repo-insight-front",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
